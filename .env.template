# ══════════════════════════════════════════════════════════════════
# .env.example — Configuration Mnemo
#
# Copie ce fichier en .env et remplis les valeurs :
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════


# ── Ressources conteneur ─────────────────────────────────────────
MNEMO_MEMORY_LIMIT=1g
MNEMO_CPU_LIMIT=2.0

# ── SearXNG (si profil search activé) ────────────────────────────
# Clé secrète pour l'instance SearXNG — changez cette valeur
# SEARXNG_SECRET_KEY=change_me_please
# URL interne Docker (ne pas modifier si SearXNG via docker compose)
SEARXNG_URL=http://localhost:8080

# ── Télémétrie CrewAI — DÉSACTIVÉE pour la confidentialité ──────
# CrewAI envoie des traces vers app.crewai.com par défaut.
# Ces deux variables coupent tout envoi externe.
OTEL_SDK_DISABLED=true
CREWAI_DISABLE_TELEMETRY=true

# ── LLM ──────────────────────────────────────────────────────────
# Modèle Ollama à utiliser pour le raisonnement.
# Format : ollama/<nom_du_modèle>
# Exemples : ollama/mistral, ollama/llama3.2, ollama/qwen2.5
MODEL=ollama/mistral

# URL de l'API Ollama — host.docker.internal pointe vers la machine hôte
# Ne pas modifier sauf si Ollama tourne sur un autre serveur.
API_BASE=http://localhost:11434


# ── Données ──────────────────────────────────────────────────────
# Dossier hôte monté dans le conteneur comme /data
# memory.db, memory.md et sessions/ seront créés ici.
# Chemin relatif (depuis docker-compose.yml) ou absolu.
DATA_DIR=./data


# ── Calendrier (optionnel) ────────────────────────────────────────
# Laisser vide pour désactiver. Le système fonctionne sans calendrier.

# Option A — Fichier ICS local (chemin DANS le conteneur, donc sous /data)
# CALENDAR_SOURCE=/data/agenda.ics

# Option B — URL Google Calendar (lien ICS privé)
# CALENDAR_SOURCE=https://calendar.google.com/calendar/ical/xxx/basic.ics

# Option C — Nextcloud / Radicale
# CALENDAR_SOURCE=https://nextcloud.local/remote.php/dav/calendars/user/default/

CALENDAR_SOURCE=

# Fenêtre de visibilité du calendrier (jours)
CALENDAR_LOOKAHEAD_DAYS=14

# ── Recherche web (optionnel) ─────────────────────────────────────
# Laisser vide pour désactiver. Le fallback DuckDuckGo est automatique
# si duckduckgo-search est installé.

# (SEARXNG_URL est désormais défini plus haut dans la section SearXNG)
# Pour une instance SearXNG externe : SEARXNG_URL=http://mon-searxng:8080

# Nombre maximum de résultats retournés par recherche
WEB_MAX_RESULTS=5

# Timeout en secondes pour les requêtes web
WEB_TIMEOUT=8

